<style>
*{margin:0;padding:0;box-sizing:border-box}:root{--p:#00695c;--s:#004d40;--d:#003531;--l:#e0f2f1;--a:#4db6ac}
body{font-family:'Inter',sans-serif;color:#333;line-height:1.6}a{text-decoration:none}
nav{position:fixed;top:0;width:100%;z-index:1000;background:rgba(255,255,255,.97);backdrop-filter:blur(10px);box-shadow:0 2px 20px rgba(0,0,0,.08);padding:15px 0}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 20px;display:flex;justify-content:space-between;align-items:center}
.logo{display:flex;align-items:center;gap:12px}.logo-text{font-weight:800;font-size:1.1rem;color:var(--d)}
.nav-links{display:flex;gap:30px;align-items:center}.nav-links a{font-weight:600;color:#666;transition:color .3s}.nav-links a:hover{color:var(--p)}
.nav-cta{background:var(--p)!important;color:#fff!important;padding:10px 24px;border-radius:8px;font-weight:700}
.hero{min-height:100vh;display:flex;align-items:center;background:linear-gradient(135deg,var(--d) 0%,var(--s) 100%);color:#fff;padding-top:80px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=1200&q=80') center/cover;opacity:.15}
.hero-inner{max-width:1200px;margin:0 auto;padding:60px 20px;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.hero h1{font-size:2.6rem;font-weight:800;line-height:1.2;margin-bottom:20px}.hero h1 span{color:var(--a)}
.hero p{font-size:1.1rem;color:rgba(255,255,255,.8);margin-bottom:30px}
.hero-image{border-radius:16px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3)}.hero-image img{width:100%;display:block}
.btn{display:inline-flex;align-items:center;gap:8px;padding:16px 36px;border-radius:10px;font-weight:700;font-size:1.1rem;transition:transform .2s}
.btn-primary{background:var(--a);color:var(--d)}.btn-primary:hover{transform:translateY(-3px)}
.trust-bar{background:#fff;padding:40px 20px;border-bottom:1px solid #eee}
.trust-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:center;gap:60px;flex-wrap:wrap}
.trust-item{text-align:center}.trust-item .icon{font-size:2rem;margin-bottom:8px}.trust-item h3{font-size:1.5rem;font-weight:800;color:var(--p)}.trust-item p{font-size:.9rem;color:#666}
.services{padding:100px 20px;background:var(--l)}.section-header{text-align:center;margin-bottom:60px}
.section-header h2{font-size:2.5rem;font-weight:800;margin-bottom:15px;color:var(--d)}.section-header p{font-size:1.1rem;color:#666;max-width:600px;margin:0 auto}
.services-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:30px}
.service-card{background:#fff;border-radius:16px;padding:40px 30px;box-shadow:0 4px 20px rgba(0,0,0,.06);transition:transform .3s;border-top:4px solid var(--p)}.service-card:hover{transform:translateY(-5px)}
.service-card .icon{font-size:2.5rem;margin-bottom:20px}.service-card h3{font-size:1.3rem;font-weight:700;margin-bottom:12px;color:var(--d)}.service-card p{color:#666}
.about{padding:100px 20px;background:#fff}.about-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.about-image{border-radius:16px;overflow:hidden;box-shadow:0 10px 40px rgba(0,0,0,.1)}.about-image img{width:100%;display:block}
.about h2{font-size:2.5rem;font-weight:800;margin-bottom:20px;color:var(--d)}.about p{color:#666;margin-bottom:15px;font-size:1.05rem}
.gallery{padding:100px 20px;background:var(--l)}.gallery-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.gallery-item{border-radius:12px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 4px 15px rgba(0,0,0,.1)}
.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .5s}.gallery-item:hover img{transform:scale(1.05)}
.contact{padding:100px 20px;background:#fff}.contact-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px}
.contact h2{font-size:2.5rem;font-weight:800;margin-bottom:20px;color:var(--d)}.contact-info{margin-top:30px}
.contact-item{display:flex;align-items:center;gap:15px;margin-bottom:25px}
.contact-item .icon{width:50px;height:50px;border-radius:12px;background:var(--l);display:flex;align-items:center;justify-content:center;font-size:1.3rem}
.contact-item h4{font-weight:700;margin-bottom:3px}.contact-item a,.contact-item p{color:#666}.contact-item a:hover{color:var(--p)}
footer{background:var(--d);color:rgba(255,255,255,.6);padding:60px 20px 30px}
.footer-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px}
footer h4{color:#fff;margin-bottom:15px;font-size:1rem}footer ul{list-style:none}footer li{margin-bottom:10px}footer a{color:rgba(255,255,255,.5);transition:color .3s}footer a:hover{color:var(--a)}
.footer-bottom{max-width:1200px;margin:40px auto 0;padding-top:30px;border-top:1px solid rgba(255,255,255,.1);text-align:center;font-size:.9rem}
@media(max-width:768px){.nav-links{display:none}.hero-inner{grid-template-columns:1fr;text-align:center}.hero h1{font-size:2rem}.hero-image{display:none}.about-inner,.contact-inner{grid-template-columns:1fr}.footer-inner{grid-template-columns:1fr}.gallery-grid{grid-template-columns:1fr}}
</style></head><body>
